generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ThumbnailSubmission {
  id        Int      @id @default(autoincrement())
  deviceId  String
  title     String
  thumbnail String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deviceId])
}
